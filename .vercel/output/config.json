{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/api/cart/?(?:/__data.json)?$",
			"dest": "/api/cart"
		},
		{
			"src": "^/api/cart/complete/?(?:/__data.json)?$",
			"dest": "/api/cart/complete"
		},
		{
			"src": "^/api/cart/receipt/?(?:/__data.json)?$",
			"dest": "/api/cart/receipt"
		},
		{
			"src": "^/api/inventory/?(?:/__data.json)?$",
			"dest": "/api/inventory"
		},
		{
			"src": "^/api/inventory/categories/?(?:/__data.json)?$",
			"dest": "/api/inventory/categories"
		},
		{
			"src": "^/api/inventory/products/?(?:/__data.json)?$",
			"dest": "/api/inventory/products"
		},
		{
			"src": "^/api/products/?(?:/__data.json)?$",
			"dest": "/api/products"
		},
		{
			"src": "^/inventory/?(?:/__data.json)?$",
			"dest": "/inventory"
		},
		{
			"src": "^/reports/?(?:/__data.json)?$",
			"dest": "/reports"
		},
		{
			"src": "^/settings/?(?:/__data.json)?$",
			"dest": "/settings"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}