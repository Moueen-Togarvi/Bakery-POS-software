{
  "name": "satluj-solar-pos-software",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "vercel:build": "vercel build",
    "vercel:verify": "node scripts/verify-vercel-output.mjs",
    "vercel:deploy:prebuilt": "npm run vercel:build && npm run vercel:verify && vercel deploy --prebuilt --prod",
    "vercel:deploy": "vercel --prod --force"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next.6",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "svelte": "^5.19.0",
    "svelte-check": "^3.8.6",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.9"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "^17.3.1",
    "html5-qrcode": "^2.3.8",
    "mongodb": "^7.1.0"
  },
  "overrides": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next.6"
  }
}
